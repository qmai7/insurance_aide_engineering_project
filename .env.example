# Copy this file to .env and fill in real values: cp .env.example .env
# .env itself is gitignored so secrets are never committed.

# Airflow (host UID that owns the bind-mounted volumes; 50000 in the official image)
AIRFLOW_UID=50000

# ClickHouse (Gold warehouse)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=gold_insurance
CLICKHOUSE_USER=changeme
CLICKHOUSE_PASSWORD=changeme

# Kafka (in-cluster listener)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# DataHub
DATAHUB_GMS_URL=http://datahub-gms:8080
DATAHUB_SECRET=replace_with_a_secret_of_at_least_32_characters
